" Default encoding
set encoding=UTF-8

" Enable Syntax highlight
syntax enable

" Line number
set number

" Relative Line Number
set relativenumber

" Set nocompatible mode
set nocompatible

" Ignore case while searching
set ignorecase
set smartcase

" Tab setting
set tabstop=4
set shiftwidth=4
set expandtab

" set line break
set linebreak
